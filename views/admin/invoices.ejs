<%- include("../partials/header") %>

<section class="hero">
  <div>
    <h1>Facturas</h1>
    <p>Listado de equipos reparados facturados. Al marcar como pagada se cierra y sale del sistema activo.</p>
  </div>
</section>

<section class="panel">
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>
  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>
  <p>
    <strong>Caja de hoy:</strong>
    <% if (todaySession) { %>
      <span class="state-badge <%= todaySession.status === 'cerrada' ? 'done' : '' %>"><%= todaySession.status %></span>
      | Empleado: <strong><%= todaySession.employee_name %></strong> | Apertura: <strong><%= formatMoney(todaySession.opening_amount) %></strong>
    <% } else { %>
      <span class="small-text">Sin apertura de caja. Debes abrir en <a href="/admin/caja">Apertura/Cierre</a>.</span>
    <% } %>
  </p>

  <div class="quote-cards">
    <% if (invoices.length === 0) { %>
      <p>No hay facturas registradas por ahora.</p>
    <% } %>
    <% invoices.forEach((invoice) => { %>
      <article class="quote-card">
        <header>
          <h3><%= invoice.invoice_number %></h3>
          <span class="state-badge <%= invoice.paid_at ? 'done' : '' %>"><%= invoice.paid_at ? 'pagada y entregada' : 'pendiente de pago' %></span>
        </header>
        <p><strong>Equipo:</strong> <%= invoice.equipment_code %> | <%= invoice.equipment_name %></p>
        <p><strong>Cliente:</strong> <%= invoice.customer_name %> - <%= invoice.customer_phone %></p>
        <% if (invoice.quote_number) { %>
          <p><strong>Cotizacion origen:</strong> <%= invoice.quote_number %></p>
        <% } %>
        <ul class="item-list">
          <% invoice.items.forEach((item) => { %>
            <li><%= item.description %> - <%= item.quantity %> x <%= formatMoney(item.unit_price) %> = <strong><%= formatMoney(item.line_total) %></strong></li>
          <% }) %>
        </ul>
        <p><strong>Total:</strong> <span class="quote-total"><%= formatMoney(invoice.total) %></span></p>
        <p class="small-text">Fecha factura: <%= formatDate(invoice.created_at) %></p>
        <% if (invoice.paid_at) { %>
          <p class="small-text">Recibido: <%= invoice.cash_received != null ? formatMoney(invoice.cash_received) : "-" %> | Cambio: <%= invoice.change_given != null ? formatMoney(invoice.change_given) : "-" %></p>
          <p class="small-text">Pagada/entregada: <%= formatDate(invoice.paid_at) %></p>
        <% } else { %>
          <form method="POST" action="/admin/facturas/<%= invoice.id %>/entregar" class="inline-input">
            <input type="number" step="0.01" min="<%= invoice.total %>" name="cash_received" value="<%= invoice.total %>" required />
            <button class="button strong" type="submit">Cobrar y entregar</button>
          </form>
        <% } %>
      </article>
    <% }) %>
  </div>
</section>

<%- include("../partials/footer") %>
