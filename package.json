{
  "name": "sr_proyect",
  "version": "1.0.0",
  "description": "Sistema de reparaciones para Santiago Reparaciones",
  "main": "electron-main.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "postinstall": "electron-builder install-app-deps",
    "electron": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-rebuild -f -w better-sqlite3 && electron-builder --win"
  },
  "build": {
    "appId": "com.santiagoreparaciones.sistema",
    "productName": "Santiago Reparaciones Modulos Car Audio",
    "asar": false,
    "buildDependenciesFromSource": true,
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!data/**",
      "!.git/**",
      "!*.md",
      "!node_modules/.cache/**"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "bwip-js": "^4.10.1",
    "ejs": "^5.0.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  }
}
